# ============================================================
# CODEWORDS – Environment Variables
# Copy this file to .env.local (web) and set actual values
# ============================================================

# ---- Socket Server (apps/socket-server) ----
PORT=4000
# The URL of your deployed web app (for CORS)
NEXT_ORIGIN=https://your-web-app.up.railway.app

# ---- Web App (apps/web) ----
# URL of your deployed socket server
NEXT_PUBLIC_SOCKET_URL=https://your-socket-server.up.railway.app

# ---- Supabase (optional – enables persistent accounts) ----
# Leave blank to run in guest-only mode
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
